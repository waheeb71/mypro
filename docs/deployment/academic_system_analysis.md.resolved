        CLUSTER_MGR["Cluster Manager (etcd)"]
    end

    subgraph "🔴 Data Plane"
        NIC["NIC (Physical)"]
        EBPF["eBPF / XDP\n~1µs drop"]
        CONNTRACK["Connection Tracker"]
        PROXY["L7 Proxy / TLS Bump"]
        PIPELINE["DPI Plugin Pipeline"]
    end

    subgraph "⚡ Event Bus — NATS/Kafka"
        BUS[" "]
    end

    subgraph "🟣 Intelligence Plane"
        UBA_E["UBA Engine"]
        ML_INF["ML Inference\n(ONNX)"]
        CORR_E["Correlation Engine"]
        THREAT_INTEL["Threat Intel Store"]
    end

    subgraph "📊 Observability Plane"
        PROM_G["Prometheus + Grafana"]
        LOKI_G["Loki (Logs)"]
        OTEL_G["OpenTelemetry (Traces)"]
    end

    ADMIN_UI --> API_GW --> POLICY_ENG --> CFG_MGR
    POLICY_ENG -->|"compiled rules"| PIPELINE
    CFG_MGR <--> CLUSTER_MGR

    CLIENT --> NIC --> EBPF
    EBPF -->|"pass"| CONNTRACK --> PROXY --> PIPELINE
    EBPF -->|"block ⚡"| X(["❌"])

    PIPELINE <-->|"events"| BUS
    BUS <--> UBA_E & ML_INF & CORR_E & THREAT_INTEL
    CORR_E -->|"block signal"| EBPF

    PIPELINE & EBPF & ML_INF --> PROM_G & LOKI_G & OTEL_G

    PROXY -->|"allowed"| INTERNET
```

